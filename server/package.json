{
  "name": "rssmonster-server",
  "version": "1.0.0",
  "type": "module",
  "description": "RSS Monster server side",
  "author": "Piethein Strengholt",
  "repository": {
    "type": "git",
    "url": "https://github.com/pietheinstrengholt/rssmonster"
  },
  "main": "bootstrap.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "fixture:semantic-export": "node scripts/exportSemanticRegressionFixture.js",
    "fixture:semantic-vectors": "node scripts/generateSemanticRegressionVectors.js",
    "fixture:semantic-incremental-vectors": "node scripts/generateSemanticRegressionIncrementalVectors.js",
    "fixture:semantic-incremental-unread-vectors": "node scripts/generateSemanticRegressionIncrementalUnreadVectors.js",
    "fixture:taxonomy-vectors": "node scripts/generateIslandTaxonomyVectorFixture.js",
    "lint": "eslint .",
    "start": "node bootstrap.js",
    "start-server": "node bootstrap.js",
    "debug": "node --watch --watch-path=./app.js --watch-path=./controllers --watch-path=./routes --watch-path=./models --watch-path=./middleware --watch-path=./util --watch-path=./config bootstrap.js",
    "db": "./node_modules/.bin/sequelize db:migrate",
    "crawl": "NODE_ENV=production node scripts/runSemanticPipeline.js",
    "recluster": "NODE_ENV=production node scripts/reclusterArticles.js",
    "build:events": "node scripts/buildEvents.js",
    "build:topics": "node scripts/buildTopics.js",
    "feedtrust": "NODE_ENV=production node scripts/calculateFeedTrust.js",
    "islands": "node scripts/buildInterestIslands.js",
    "backfill:engaged-vectors": "NODE_ENV=production node scripts/backfillEngagedArticleVectors.js",
    "taxonomy:vectors": "node scripts/generateIslandTaxonomyVectors.js",
    "seed:island-taxonomy": "./node_modules/.bin/sequelize db:seed --seed 20260520104500-island-taxonomy.js",
    "seed:undo:island-taxonomy": "./node_modules/.bin/sequelize db:seed:undo --seed 20260520104500-island-taxonomy.js",
    "hotlinks": "NODE_ENV=production node scripts/rebuildHotlinks.js",
    "reset:semantic": "node scripts/resetSemanticState.js"
  },
  "engines": {
    "node": ">=20.x"
  },
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.39.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.11.6",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "feedsmith": "^2.9.4",
    "franc-min": "^6.2.0",
    "he": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.4",
    "node-cache": "^5.1.2",
    "openai": "^6.42.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  }
}
